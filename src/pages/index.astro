---
import Layout from "@/layouts/Layout.astro";
import ProfileSidebar from "@/components/sections/ProfileSidebar";
import { HeroBio, RecentNews } from "@/components/sections/HeroBio";
import { HomePublications } from "@/components/sections/HomePublications";
import { HomeArticles } from "@/components/sections/HomeArticles";
import { getSortedPublishedArticles } from "@/utils/articles";
import { readSiteJson } from "@/utils/json-data";

const about = await readSiteJson("about.json");
const lifeEvents = await readSiteJson<Record<string, unknown>>("life_events.json");
const publications = await readSiteJson("publications.json");
const articles = await getSortedPublishedArticles();
---

<Layout>
  <section class="grid grid-cols-1 lg:grid-cols-[240px_1fr] gap-[clamp(28px,5vw,56px)] mb-12">
    <ProfileSidebar client:load about={about} />
    <div>
      <HeroBio client:load about={about} />
      <RecentNews client:load lifeEvents={lifeEvents} />
      <HomePublications client:load publications={publications} />
      <HomeArticles client:load articles={articles} />
    </div>
  </section>
</Layout>
