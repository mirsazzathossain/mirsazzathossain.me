---
import Layout from "@/layouts/Layout.astro";
import SimpleLayout from "@/components/SimpleLayout";
import ListCourses from "@/components/ListCourses";
import { readSiteJson } from "@/utils/json-data";

const courses = await readSiteJson<Course[]>("courses.json");
---

<Layout
  title="Courses"
  description="Tutorial sessions, lab worksheets, and tutorial materials I've prepared as a teaching assistant at IUB."
  canonicalPath="/courses"
>
  <SimpleLayout
    eyebrow="Teaching"
    title="Courses"
    intro="Tutorial sessions, lab worksheets, and tutorial materials I've prepared as a teaching assistant at IUB. Click any course for full syllabus, weekly schedule, and notebooks."
  >
    <div class="mt-8">
      <ListCourses courses={courses} />
    </div>
  </SimpleLayout>
</Layout>
