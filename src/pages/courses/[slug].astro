---
import Layout from "@/layouts/Layout.astro";
import { readSiteJson } from "@/utils/json-data";

export async function getStaticPaths() {
  const courses = await readSiteJson<Course[]>("courses.json");
  return courses.map((course) => ({
    params: { slug: course.slug },
    props: { course },
  }));
}

interface Props {
  course: Course;
}

const { course } = Astro.props;
---

<Layout
  title={course.title}
  description={course.syllabus ?? course.description}
  canonicalPath={`/courses/${course.slug}`}
>
  <div class="grid grid-cols-1 lg:grid-cols-[220px_1fr] gap-9 mt-2">

    {/* Sidebar */}
    <aside class="lg:sticky lg:top-[80px] lg:self-start flex flex-col gap-0">
      <a href="/courses" class="font-mono text-[12px] text-ink-2 hover:text-link mb-[14px] inline-flex items-center gap-1 transition-colors">
        <svg class="w-[10px] h-[10px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        All courses
      </a>

      {/* Course code callout */}
      <div class="p-[14px_16px] border border-rule rounded-[6px] bg-bg-2 mb-3">
        <div class="font-mono text-[10.5px] tracking-[0.1em] uppercase text-ink-3 mb-1">Course code</div>
        <div class="font-mono text-[16px] text-ink font-semibold">{course.code}</div>
      </div>

      {/* On this page */}
      <div class="p-[14px_16px] border border-rule rounded-[6px] bg-bg-2">
        <div class="font-mono text-[10.5px] tracking-[0.1em] uppercase text-ink-3 mb-2">On this page</div>
        <ul class="list-none p-0 m-0 flex flex-col gap-[6px]">
          {course.syllabus && <li><a href="#syllabus" class="text-[12.5px] text-ink-2 hover:text-link transition-colors">Syllabus</a></li>}
          {course.schedule && course.schedule.length > 0 && <li><a href="#schedule" class="text-[12.5px] text-ink-2 hover:text-link transition-colors">Weekly schedule</a></li>}
          {course.notebooks && course.notebooks.length > 0 && <li><a href="#notebooks" class="text-[12.5px] text-ink-2 hover:text-link transition-colors">Tutorial notebooks</a></li>}
          {course.resources && course.resources.length > 0 && <li><a href="#resources" class="text-[12.5px] text-ink-2 hover:text-link transition-colors">Resources</a></li>}
        </ul>
      </div>
    </aside>

    {/* Main content */}
    <main>
      <p class="font-mono text-[11px] tracking-[0.14em] uppercase text-ink-3 m-0 mb-[6px]">{course.role} · {course.term}</p>
      <h1 class="font-serif text-[clamp(22px,3.5vw,28px)] leading-[1.15] tracking-[-0.018em] m-0 mb-2 text-ink">{course.title}</h1>
      <p class="text-[13px] text-ink-3 m-0 mb-[14px]">{course.inst}</p>

      {/* Meta strip */}
      <div class="flex flex-wrap gap-[14px] py-[14px] border-t border-b border-rule mb-[22px] font-mono text-[12px] text-ink-2">
        <span class="inline-flex items-center gap-[5px]">
          <svg class="w-[11px] h-[11px] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          {course.term}
        </span>
        <span class="inline-flex items-center gap-[5px]">
          <svg class="w-[11px] h-[11px] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          {course.inst}
        </span>
        {course.students && (
          <span class="inline-flex items-center gap-[5px]">
            👥 {course.students} students
          </span>
        )}
        {course.repo && course.repo !== "#" && (
          <span class="inline-flex items-center gap-[5px]">
            <svg class="w-[11px] h-[11px] shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/></svg>
            <a href={course.repo} class="text-link hover:underline" target="_blank" rel="noreferrer">Course repository</a>
          </span>
        )}
      </div>

      {/* Syllabus section */}
      {course.syllabus && (
        <section id="syllabus" class="mb-[26px]">
          <h2 class="font-mono text-[11px] tracking-[0.14em] uppercase text-ink-3 m-0 mb-[10px] pb-[6px] border-b border-rule">Syllabus</h2>
          <p class="font-serif text-[16px] leading-[1.62] text-ink m-0 mb-3 max-w-[65ch]">{course.syllabus}</p>
          {course.outcome && (
            <div class="p-[14px_16px] border border-rule rounded-[6px] bg-bg-2">
              <div class="font-mono text-[10.5px] tracking-[0.1em] uppercase text-ink-3 mb-1">Learning outcome</div>
              <div class="text-[13.5px] text-ink-2 leading-[1.55]">{course.outcome}</div>
            </div>
          )}
        </section>
      )}

      {/* Schedule section */}
      {course.schedule && course.schedule.length > 0 && (
        <section id="schedule" class="mb-[26px]">
          <h2 class="font-mono text-[11px] tracking-[0.14em] uppercase text-ink-3 m-0 mb-[10px] pb-[6px] border-b border-rule">Weekly schedule</h2>
          <ol class="list-none p-0 m-0">
            {course.schedule.map((item, i) => (
              <li class="grid grid-cols-[140px_1fr] gap-[14px] border-b border-rule-2 py-[9px] text-[13.5px] last:border-b-0">
                <span class="font-mono text-[11.5px] text-link">{item.week}</span>
                <span class="text-ink-2">{item.topic}</span>
              </li>
            ))}
          </ol>
        </section>
      )}

      {/* Notebooks section */}
      {course.notebooks && course.notebooks.length > 0 && (
        <section id="notebooks" class="mb-[26px]">
          <h2 class="font-mono text-[11px] tracking-[0.14em] uppercase text-ink-3 m-0 mb-[10px] pb-[6px] border-b border-rule">Tutorial notebooks</h2>
          <div class="grid gap-2">
            {course.notebooks.map((nb) => (
              <div class="grid grid-cols-[36px_1fr_auto] items-center gap-3 rounded-[6px] border border-rule bg-bg p-[10px_12px]">
                <span class="font-mono text-[11px] text-ink-3">#{nb.n}</span>
                <span class="text-[13.5px] text-ink">{nb.title}</span>
                {course.repo && course.repo !== "#" ? (
                  <a href={course.repo} target="_blank" rel="noreferrer" class="font-mono text-[11.5px] text-link hover:underline whitespace-nowrap inline-flex items-center gap-1">
                    <svg class="w-[10px] h-[10px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    .ipynb
                  </a>
                ) : (
                  <span class="font-mono text-[11.5px] text-ink-3 whitespace-nowrap">coming soon</span>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      {/* Resources section */}
      {course.resources && course.resources.length > 0 && (
        <section id="resources" class="mb-[26px]">
          <h2 class="font-mono text-[11px] tracking-[0.14em] uppercase text-ink-3 m-0 mb-[10px] pb-[6px] border-b border-rule">Resources &amp; references</h2>
          <ul class="list-none p-0 m-0 grid gap-2">
            {course.resources.map((r) => (
              <li class="flex justify-between items-center p-[10px_12px] border border-rule rounded-[6px] text-[13.5px]">
                <span class="text-ink">{r.title}</span>
                <a href={r.href} class="font-mono text-[11.5px] text-link hover:underline ml-4 shrink-0 inline-flex items-center gap-1" target="_blank" rel="noreferrer">
                  <svg class="w-[10px] h-[10px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  open
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </main>
  </div>
</Layout>
