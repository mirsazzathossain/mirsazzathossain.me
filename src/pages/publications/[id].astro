---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PublicationLayout from "@/components/publications/PublicationLayout.astro";
import { mergePublicationOverrides, type Publication } from "@/utils/publications";
import base from "@/data/publications.json";
import overrides from "@/data/publications.override.json";

export async function getStaticPaths() {
  const publications = mergePublicationOverrides(
    base as Publication[],
    overrides as Partial<Publication>[]
  );

  return publications
    .filter((p) => p.id)
    .map((p) => ({
      params: { id: p.slug || p.id },
      props: { publication: p },
    }));
}

const { publication } = Astro.props;
const urlSlug = publication.slug || publication.id;

const allMdx = await getCollection("publications");
const mdxEntry = allMdx.find((e) => e.id === urlSlug);
const Content = mdxEntry ? (await render(mdxEntry)).Content : null;
---

<Layout
  title={publication.title}
  description={publication.abstract ?? publication.title}
  canonicalPath={`/publications/${urlSlug}`}
>
  {Content ? (
    <PublicationLayout publication={publication} hasMdx={true}>
      <Content />
    </PublicationLayout>
  ) : (
    <PublicationLayout publication={publication} />
  )}
</Layout>

<script is:inline>
  document.addEventListener("click", async (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const button = target.closest("[data-copy-cite]");
    if (!button) return;

    const block = button.closest(".block-code");
    const text = block?.querySelector("pre")?.textContent?.trim() || "";
    const label = button.querySelector("[data-copy-label]");

    const reset = () => {
      if (label) label.textContent = "Copy";
      button.setAttribute("aria-label", "Copy citation");
    };

    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(text);
      } else {
        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.opacity = "0";
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand("copy");
        document.body.removeChild(textarea);
      }

      if (label) label.textContent = "Copied";
      button.setAttribute("aria-label", "Citation copied");
      window.setTimeout(reset, 1600);
    } catch {
      if (label) label.textContent = "Failed";
      window.setTimeout(reset, 1600);
    }
  });
</script>