---
import Layout from "@/layouts/Layout.astro";
import SimpleLayout from "@/components/SimpleLayout";
import ListSnippets from "@/components/ListSnippets";
import { getCollection } from "astro:content";

const snippets = await getCollection("snippets");
---

<Layout
  title="Snippets"
  description="Tiny, copy-paste-ready solutions for tasks I keep running into."
  canonicalPath="/snippets"
>
  <SimpleLayout
    eyebrow="Reference"
    title="Snippets"
    intro="Tiny, copy-paste-ready solutions for tasks I keep running into — kept here so I (and you) don't re-derive them from scratch."
  >
    <ListSnippets client:load snippets={snippets} />
  </SimpleLayout>
</Layout>