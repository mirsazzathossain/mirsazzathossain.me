---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";

const snippets = await getCollection("snippets");
---

<Layout
  title="Snippets"
  description="Tiny, copy-paste-ready solutions for tasks I keep running into."
  canonicalPath="/snippets"
>
  <div class="mb-8">
    <header class="max-w-[720px] mb-8">
      <p class="font-mono text-[11px] tracking-[0.14em] uppercase text-ink-3 m-0 mb-1.5 font-semibold">
        Reference
      </p>
      <h1 class="font-serif text-[clamp(28px,4.5vw,42px)] leading-[1.05] tracking-[-0.02em] m-0 text-ink font-bold">
        Snippets
      </h1>
      <p class="mt-3 text-[15px] text-ink-2 max-w-[60ch] m-0">
        Tiny, copy-paste-ready solutions for tasks I keep running into - kept here so I (and you) don't re-derive them from scratch.
      </p>
    </header>

    <div class="mb-[22px]">
      <label class="inline-flex items-center gap-[7px] py-1.5 px-3 border border-rule rounded-full bg-bg min-w-full sm:min-w-[260px] lg:min-w-[320px] text-ink-3">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="h-[13px] w-[13px] shrink-0">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <span class="sr-only">Search snippets</span>
        <input
          id="snippets-search"
          type="text"
          placeholder="Search snippets..."
          class="w-full border-0 outline-none bg-transparent font-sans text-[13px] text-ink placeholder:text-ink-3"
        />
      </label>
    </div>

    <div class="grid gap-[18px] [grid-template-columns:repeat(auto-fill,minmax(320px,1fr))]">
      {snippets.map((s) => (
        <a
          data-snippet=""
          data-search={`${s.data.title} ${s.data.description} ${s.data.language}`.toLowerCase()}
          href={`/snippets/${s.id}`}
          class="relative flex flex-col gap-2 rounded-[14px] border border-rule bg-bg p-[22px_22px_20px] no-underline transition-[border-color,box-shadow,transform] duration-[180ms] hover:-translate-y-0.5 hover:border-link/45 hover:shadow-lg hover:no-underline"
        >
          <span class="relative mb-1 inline-flex h-[38px] w-[38px] items-center justify-center text-ink-2">
            {s.data.logo?.url && (
              <img
                src={`/images/${s.data.logo.url}`}
                alt={s.data.logo.alt}
                width={26}
                height={26}
                class="object-contain"
              />
            )}
            {!s.data.logo?.url && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round" aria-hidden="true" class="h-[22px] w-[22px]">
                <path d="M5 7.2 12 3l7 4.2v9.6L12 21l-7-4.2Z" />
              </svg>
            )}
            {!s.data.logo?.url && (
              <span class="absolute inset-0 flex items-center justify-center font-mono text-[8.5px] font-bold tracking-[-0.04em] text-ink-3">
                {s.data.language.slice(0, 3)}
              </span>
            )}
          </span>
          <h3 class="m-0 font-sans text-[17px] font-bold leading-[1.3] tracking-[-0.014em] text-ink">
            {s.data.title}
          </h3>
          <p class="m-0 text-[13.5px] leading-[1.55] text-ink-2">
            {s.data.description}
          </p>
          <div class="mt-1.5 flex flex-wrap gap-1.5">
            <span class="rounded-full border border-link/25 bg-accent-soft px-3 py-[3px] text-[11.5px] font-medium text-link">
              {s.data.language}
            </span>
          </div>
        </a>
      ))}
    </div>
    <p id="snippets-empty" hidden class="font-mono text-sm text-ink-3">
      No snippets match your search.
    </p>
  </div>
</Layout>

<script>
  const input = document.getElementById("snippets-search") as HTMLInputElement;
  const emptyEl = document.getElementById("snippets-empty") as HTMLElement;

  input.addEventListener("input", () => {
    const needle = input.value.trim().toLowerCase();
    let visible = 0;
    document.querySelectorAll<HTMLElement>("[data-snippet]").forEach((el) => {
      const show = !needle || el.dataset.search!.includes(needle);
      el.hidden = !show;
      if (show) visible++;
    });
    emptyEl.hidden = visible > 0;
  });
</script>
