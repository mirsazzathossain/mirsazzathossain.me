---
import mdxComponents from "@/components/mdx/mdx-map";
import Layout from "@/layouts/Layout.astro";
import { getSnippetLanguageMeta } from "@/utils/snippets";
import { getCollection, getEntry, render } from "astro:content";

export async function getStaticPaths() {
  const snippets = await getCollection("snippets");
  return snippets.map((s) => ({ params: { slug: s.id } }));
}

const { slug } = Astro.params;
const entry = await getEntry("snippets", slug!);
if (!entry) return Astro.redirect("/404");

const { Content } = await render(entry);

const meta = getSnippetLanguageMeta(entry.data.language);
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={`/snippets/${entry.id}`}
>
  <article class="mx-auto max-w-[var(--max-narrow)]">

    <a href="/snippets" class="mb-[18px] inline-block font-mono text-[12px] text-ink-3 no-underline transition-colors hover:text-link hover:no-underline">← All snippets</a>

    <header class="mb-[26px] flex items-start gap-[18px] border-b border-rule pb-[22px]">
      <div class="min-w-0 flex-1">
        <h1 class="m-0 mb-2 font-sans text-[clamp(24px,3.6vw,32px)] font-bold leading-[1.18] tracking-[-0.02em] text-ink">
          {entry.data.title}
        </h1>
        <p class="m-0 mb-3 max-w-[60ch] text-[14.5px] leading-[1.55] text-ink-2">
          {entry.data.description}
        </p>
        <div class="flex flex-wrap gap-1.5">
          <span class="rounded-full border border-link/25 bg-accent-soft px-3 py-[3px] text-[11.5px] font-medium text-link">Snippet</span>
          <span class="rounded-full border border-rule bg-bg-2 px-3 py-[3px] text-[11.5px] font-medium text-ink-2">{meta.label}</span>
        </div>
      </div>
      <span aria-hidden="true" class="relative inline-flex h-[50px] w-[50px] shrink-0 items-center justify-center text-ink-2">
        {entry.data.logo?.url ? (
          <img src={`/images/${entry.data.logo.url}`} alt={entry.data.logo.alt} width="36" height="36" class="object-contain" />
        ) : (
          <>
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round">
              <path d="M5 7.2 12 3l7 4.2v9.6L12 21l-7-4.2Z"/>
            </svg>
            <span class:list={["absolute inset-0 flex items-center justify-center font-mono text-[11px] font-bold tracking-[-0.04em]", meta.glyphClassName]}>{meta.glyph}</span>
          </>
        )}
      </span>
    </header>

    <div class="prose dark:prose-invert prose-code:font-mono">
      <Content components={mdxComponents} />
    </div>

  </article>
</Layout>
