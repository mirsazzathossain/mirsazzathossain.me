---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Page not found">
  <div class="mx-auto max-w-xl px-4 py-24 text-center">
    <h1 class="text-4xl font-bold text-zinc-800 dark:text-zinc-100">404</h1>
    <p class="mt-4 text-zinc-600 dark:text-zinc-400">This page could not be found.</p>
    <a
      href="/"
      class="mt-8 inline-block text-teal-600 hover:underline dark:text-teal-400"
    >
      Back home
    </a>
  </div>
</Layout>
