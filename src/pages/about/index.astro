---
import AboutPage from "@/components/about/AboutPage";
import Layout from "@/layouts/Layout.astro";
import { readSiteJson } from "@/utils/json-data";

const about = await readSiteJson("about.json");
const educations = await readSiteJson("educations.json");
const experiences = await readSiteJson("experiences.json");
const awards = await readSiteJson("awards.json");
const talks = await readSiteJson("talks.json");
const service = await readSiteJson("service.json");
const press = await readSiteJson("press.json");
const availability = await readSiteJson("availability.json");
const timeline = await readSiteJson("news.json");
---

<Layout
  title="About"
  name={about.name}
  description={`About ${about.name} — Junior Research Scientist at CCDS, Independent University, Bangladesh. Research in computer vision, domain adaptation, and vision-language models.`}
>
  <AboutPage
    client:load
    about={about}
    educations={educations}
    experiences={experiences}
    awards={awards}
    talks={talks}
    service={service}
    press={press}
    availability={availability}
    timeline={timeline}
  />
</Layout>
