---
import Layout from "@/layouts/Layout.astro";
import AboutPage from "@/components/AboutPage";
import { readSiteJson } from "@/utils/json-data";

const about = await readSiteJson("about.json");
const educations = await readSiteJson("educations.json");
const experiences = await readSiteJson("experiences.json");
const awards = await readSiteJson("about_awards.json");
const talks = await readSiteJson("about_talks.json");
const service = await readSiteJson("about_service.json");
const press = await readSiteJson("about_press.json");
const availability = await readSiteJson("about_availability.json");
const timeline = await readSiteJson("about_timeline.json");
---

<Layout
  title="About"
  description="About Mir Sazzat Hossain — Junior Research Scientist at CCDS, Independent University, Bangladesh. Research in computer vision, domain adaptation, and vision-language models."
>
  <AboutPage
    client:load
    about={about}
    educations={educations}
    experiences={experiences}
    awards={awards}
    talks={talks}
    service={service}
    press={press}
    availability={availability}
    timeline={timeline}
  />
</Layout>
