---
import Layout from "@/layouts/Layout.astro";
import SimpleLayout from "@/components/SimpleLayout";
import SearchArticles from "@/components/articles/SearchArticles";
import { getSortedPublishedArticles } from "@/utils/articles";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const articles = await getSortedPublishedArticles();
  return paginate(articles, { pageSize: 5 });
};

const allArticles = await getSortedPublishedArticles();
const { page } = Astro.props;
---

<Layout
  title={page.currentPage > 1 ? `Articles (page ${page.currentPage})` : "Articles"}
  description="All my articles are written with the goal of helping you learn something new. I hope you enjoy them!"
  canonicalPath={page.url.current}
>
  <SimpleLayout
    title="Writing on Machine Learning, Advance Math, and Programming"
    intro="All my articles are written with the goal of helping you learn something new. I hope you enjoy them!"
  >
    <SearchArticles
      client:load
      allArticles={allArticles}
      page={page}
      paginationBase="/articles/list"
    />
  </SimpleLayout>
</Layout>
