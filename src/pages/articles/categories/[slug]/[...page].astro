---
import Layout from "@/layouts/Layout.astro";
import PostsList from "@/components/articles/PostsList";
import { getSortedPublishedArticles } from "@/utils/articles";
import { slugify } from "@/utils/slugify";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const articles = await getSortedPublishedArticles();
  const slugs = new Set<string>();
  for (const article of articles) {
    for (const category of article.data.categories) {
      slugs.add(slugify(category.title));
    }
  }

  return [...slugs].flatMap((slug) => {
    const filtered = articles.filter((article) =>
      article.data.categories.some((category) => slugify(category.title) === slug),
    );
    if (!filtered.length) return [];
    return paginate(filtered, { pageSize: 20, params: { slug } });
  });
};

const allArticles = await getSortedPublishedArticles();
const { slug } = Astro.params;
const allForCategory = allArticles.filter((article) =>
  article.data.categories.some((category) => slugify(category.title) === slug),
);
const { page } = Astro.props;

if (!slug || !allForCategory.length) {
  return Astro.redirect("/404");
}

const categoryTitle =
  allForCategory[0].data.categories.find(
    (category) => slugify(category.title) === slug,
  )?.title ?? slug;
---

<Layout
  title={
    page.currentPage > 1
      ? `${categoryTitle} - Posts (page ${page.currentPage})`
      : `Posts in ${categoryTitle}`
  }
  description={`Posts in ${categoryTitle}.`}
  canonicalPath={page.url.current}
>
  <header class="mb-8 max-w-[720px]">
    <p class="m-0 mb-1.5 font-mono text-[11px] tracking-[0.14em] uppercase text-ink-3">
      Category
    </p>
    <h1 class="m-0 font-serif text-[clamp(28px,4.5vw,42px)] font-semibold leading-[1.05] tracking-[-0.02em] text-ink">
      {categoryTitle}
    </h1>
    <p class="mt-3 mb-0 max-w-[60ch] text-[15px] text-ink-2">
      Posts and notes in {categoryTitle}.
    </p>
  </header>

  <PostsList client:load articles={allForCategory} initialPage={page.currentPage} />
</Layout>
