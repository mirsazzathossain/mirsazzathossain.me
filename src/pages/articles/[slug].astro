---
import ArticleShareRow from "@/components/articles/ArticleShareRow";
import Comments from "@/components/articles/Comments";
import Layout from "@/layouts/Layout.astro";
import mdxComponents from "@/components/mdx/mdx-map";
import {
  getRelatedArticles,
  getSortedPublishedArticles,
  tagHref,
} from "@/utils/articles";
import { cleanMarkdownHeading, slugify } from "@/utils/slugify";
import { getCollection, getEntry, render } from "astro:content";
import readingTime from "@/utils/reading-time";

export async function getStaticPaths() {
  const posts = await getCollection("articles", ({ data }) => {
    return data.status === "published";
  });
  return posts.map((post) => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const entry = await getEntry("articles", slug!);

if (!entry) {
  return Astro.redirect("/404");
}

const sortedArticles = await getSortedPublishedArticles();
const currentIndex = sortedArticles.findIndex((article) => article.id === entry.id);
const previousArticle = sortedArticles[currentIndex + 1];
const nextArticle = sortedArticles[currentIndex - 1];
const relatedArticles = getRelatedArticles(entry, sortedArticles);

const { Content } = await render(entry);

const rt = readingTime(entry.body);
const siteOrigin = Astro.site?.href.replace(/\/$/, "") ?? "";
const articleUrl = `${siteOrigin}/articles/${entry.id}`;

const published = entry.data.publishedAt
  ? new Date(entry.data.publishedAt).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";

const primaryCategory = entry.data.categories[0]?.title ?? "Post";
const toc = Array.from(entry.body.matchAll(/^(#{2,3})\s+(.+)$/gm)).map(
  ([, depth, text]) => {
    const title = cleanMarkdownHeading(text);
    return {
      depth: depth.length,
      title,
      id: slugify(title),
    };
  },
);
const referenceItems = entry.data.references ?? [];
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={`/articles/${entry.id}`}
  ogImage={`/images/${entry.data.covers[0]?.url ?? "og-image.png"}`}
  ogType="article"
  publishedTime={entry.data.publishedAt?.toISOString()}
  authors={[entry.data.author.name]}
  keywords={[
    ...(entry.data.tags?.map((t) => t.title) ?? []),
    ...entry.data.categories.map((c) => c.title),
  ]}
>
  <article class="mx-auto max-w-[740px]">
    <a
      href="/articles/"
      class="mb-[18px] inline-block font-mono text-[12px] text-ink-3 transition-colors hover:text-link hover:no-underline"
    >
      &larr; All posts
    </a>

    <header class="mb-7 border-b border-rule pb-[22px]">
      <div class="mb-2.5 flex flex-wrap gap-2">
        <span class="rounded-[3px] border border-link/25 bg-accent-soft px-[7px] py-[2px] font-mono text-[10px] font-medium tracking-[0.04em] text-link">
          {primaryCategory}
        </span>
      </div>
      <h1 class="m-0 mb-3.5 font-serif text-[clamp(28px,4.5vw,38px)] font-semibold leading-[1.15] tracking-[-0.02em] text-ink">
        {entry.data.title}
      </h1>
      <div class="flex flex-wrap gap-3.5 font-mono text-[12px] text-ink-3">
        <span class="inline-flex items-center gap-[5px]">
          <svg class="h-[11px] w-[11px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          {published}
        </span>
        <span class="inline-flex items-center gap-[5px]">
          <svg class="h-[11px] w-[11px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          {rt.text}
        </span>
        {
          entry.data.tags?.slice(0, 3).map((tag) => (
            <a
              href={tagHref(tag.title)}
              class="inline-flex items-center gap-[5px] text-ink-3 transition-colors hover:text-link hover:no-underline"
            >
              <svg class="h-[11px] w-[11px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20.59 13.41 13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                <line x1="7" y1="7" x2="7.01" y2="7"></line>
              </svg>
              {tag.title}
            </a>
          ))
        }
      </div>
    </header>

    {
      toc.length > 0 && (
        <nav class="mb-8 rounded border border-rule bg-bg-2 px-4 py-3.5">
          <h2 class="m-0 mb-2 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-ink-3">
            On this page
          </h2>
          <ol class="m-0 grid list-none gap-1.5 p-0 font-mono text-[12px] leading-[1.5]">
            {toc.map((item) => (
              <li class={item.depth === 3 ? "pl-4" : ""}>
                <a
                  href={`#${item.id}`}
                  class="text-ink-2 transition-colors hover:text-link hover:no-underline"
                >
                  {item.title}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      )
    }

    <div class="post-body font-serif text-[17px] leading-[1.7] text-ink">
      <p>{entry.data.description}</p>
      <Content components={mdxComponents} />
    </div>

    <ArticleShareRow client:load title={entry.data.title} url={articleUrl} />

    {
      referenceItems.length > 0 && (
        <div class="my-8 rounded border border-rule bg-bg-2 px-4 py-3.5">
          <h2 class="m-0 mb-2 font-mono text-[11px] font-semibold tracking-[0.12em] uppercase text-ink-3">
            References
          </h2>
          <ol class="m-0 grid list-decimal gap-2 pl-5">
            {referenceItems.map((item) => (
              <li class="text-[13px] leading-[1.55] text-ink-2">
                {item.href ? (
                  <a
                    href={item.href}
                    class="break-words text-link underline decoration-link/30 underline-offset-4 hover:decoration-link"
                  >
                    {item.text}
                  </a>
                ) : (
                  item.text
                )}
              </li>
            ))}
          </ol>
        </div>
      )
    }

    <div class="mt-8 flex items-center gap-3.5 rounded-[10px] border border-rule bg-bg-2 p-[22px]">
      <img
        src={`/images/${entry.data.author.avatar.url}`}
        alt={entry.data.author.avatar.alt}
        class="h-14 w-14 shrink-0 rounded-full object-cover"
      />
      <div>
        <p class="m-0 font-serif text-[16px] leading-tight text-ink">
          {entry.data.author.name}
        </p>
        <p class="m-0 mt-0.5 text-[13px] leading-[1.55] text-ink-2">
          Junior Research Scientist at CCDS, IUB. Working on computer vision,
          domain adaptation, and the occasional radio-galaxy problem.
        </p>
      </div>
    </div>

    <div class="mt-[26px] grid grid-cols-1 gap-3 sm:grid-cols-2">
      {
        previousArticle ? (
          <a
            href={`/articles/${previousArticle.id}`}
            class="block rounded border border-rule bg-bg px-4 py-3.5 transition-colors hover:border-link hover:no-underline"
          >
            <div class="mb-[5px] font-mono text-[10.5px] tracking-[0.1em] uppercase text-ink-3">
              &larr; Previous
            </div>
            <div class="font-serif text-[14.5px] leading-[1.35] text-ink">
              {previousArticle.data.title}
            </div>
          </a>
        ) : (
          <div />
        )
      }
      {
        nextArticle ? (
          <a
            href={`/articles/${nextArticle.id}`}
            class="block rounded border border-rule bg-bg px-4 py-3.5 text-right transition-colors hover:border-link hover:no-underline"
          >
            <div class="mb-[5px] font-mono text-[10.5px] tracking-[0.1em] uppercase text-ink-3">
              Next &rarr;
            </div>
            <div class="font-serif text-[14.5px] leading-[1.35] text-ink">
              {nextArticle.data.title}
            </div>
          </a>
        ) : (
          <div />
        )
      }
    </div>

    {
      relatedArticles.length > 0 && (
        <section class="mt-9">
          <h2 class="m-0 mb-3.5 border-b border-rule pb-2 font-mono text-[11px] font-semibold tracking-[0.14em] uppercase text-ink-3">
            Related posts
          </h2>
          <div class="grid grid-cols-1 gap-3.5 sm:grid-cols-2">
            {relatedArticles.map((article) => {
              const date = article.data.publishedAt
                ? article.data.publishedAt.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })
                : "";
              const read = readingTime(article.body);
              return (
                <a
                  href={`/articles/${article.id}`}
                  class="rounded border border-rule bg-bg px-4 py-3.5 transition-colors hover:border-link hover:no-underline"
                >
                  <div class="mb-1 font-mono text-[11px] text-ink-3">
                    {date} · {read.text}
                  </div>
                  <div class="font-serif text-[15px] leading-[1.3] text-ink">
                    {article.data.title}
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )
    }

    <Comments client:load />
  </article>
</Layout>

<script is:inline>
  const slugifyHeading = (text) =>
    text
      .toLowerCase()
      .trim()
      .replace(/[^\w\s-]/g, "")
      .replace(/[\s_-]+/g, "-")
      .replace(/^-+|-+$/g, "");

  document.querySelectorAll(".post-body h2, .post-body h3").forEach((heading) => {
    if (!heading.id) {
      heading.id = slugifyHeading(heading.textContent || "");
    }
  });
</script>
