---
import Layout from "@/layouts/Layout.astro";
import PostsList from "@/components/articles/PostsList";
import { getSortedPublishedArticles } from "@/utils/articles";
import { slugify } from "@/utils/slugify";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const articles = await getSortedPublishedArticles();
  const slugs = new Set<string>();
  for (const article of articles) {
    for (const tag of article.data.tags ?? []) {
      slugs.add(slugify(tag.title));
    }
  }

  return [...slugs].flatMap((slug) => {
    const filtered = articles.filter((article) =>
      article.data.tags?.some((tag) => slugify(tag.title) === slug),
    );
    if (!filtered.length) return [];
    return paginate(filtered, { pageSize: 20, params: { slug } });
  });
};

const allArticles = await getSortedPublishedArticles();
const { slug } = Astro.params;
const allForTag = allArticles.filter((article) =>
  article.data.tags?.some((tag) => slugify(tag.title) === slug),
);
const { page } = Astro.props;

if (!slug || !allForTag.length) {
  return Astro.redirect("/404");
}

const tagTitle =
  allForTag[0].data.tags?.find((tag) => slugify(tag.title) === slug)?.title ??
  slug;
---

<Layout
  title={
    page.currentPage > 1
      ? `${tagTitle} - Posts (page ${page.currentPage})`
      : `Posts tagged with ${tagTitle}`
  }
  description={`Posts tagged with ${tagTitle}.`}
  canonicalPath={page.url.current}
>
  <header class="mb-8 max-w-[720px]">
    <p class="m-0 mb-1.5 font-mono text-[11px] tracking-[0.14em] uppercase text-ink-3">
      Tag
    </p>
    <h1 class="m-0 font-serif text-[clamp(28px,4.5vw,42px)] font-semibold leading-[1.05] tracking-[-0.02em] text-ink">
      {tagTitle}
    </h1>
    <p class="mt-3 mb-0 max-w-[60ch] text-[15px] text-ink-2">
      Posts and notes tagged with {tagTitle}.
    </p>
  </header>

  <PostsList client:load articles={allForTag} initialPage={page.currentPage} />
</Layout>
